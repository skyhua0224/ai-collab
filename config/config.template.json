        "patterns": ["debug", "调试", "fix", "bug", "crash", "错误", "问题"],
        "primary": "codex",
        "reviewers": ["claude"],
        "workflow": "debug-fix-verify"
      },
      {
        "name": "security-audit",
        "description": "Security scanning and remediation",
        "patterns": ["security", "安全", "漏洞", "audit", "owasp", "证书", "认证"],
        "primary": "claude",
        "reviewers": ["codex", "gemini"],
        "workflow": "security-remediation"
      },
      {
        "name": "research",
        "description": "Research and alternatives analysis",
        "patterns": ["research", "调研", "探索", "对比", "study", "benchmark", "比较"],
        "primary": "gemini",
        "reviewers": ["claude"],
        "workflow": "research-synthesis"
      },
      {
        "name": "testing",
        "description": "Test planning and execution",
        "patterns": ["test", "测试", "tdd", "coverage", "回归", "验证"],
