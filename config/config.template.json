        "description": "Native Android/iOS development",
        "patterns": ["android", "ios", "swiftui", "kotlin", "jetpack", "xcodeproj", "gradle"],
        "primary": "codex",
        "reviewers": ["claude", "gemini"],
        "workflow": "mobile-native"
      },
      {
        "name": "systems-tooling",
        "description": "Systems-level tooling with bash/python/node/rust",
        "patterns": ["bash", "python", "nodejs", "rust", "cli", "脚本", "自动化", "pipeline", "工具链"],
        "primary": "codex",
